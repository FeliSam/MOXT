VITE_API_URL=http://localhost:4000/api

# Supabase (clés publiques — anon key conçue pour être exposée côté client)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# Telegram Gateway (secret serveur — NE PAS mettre dans VITE_*)
# Configurer sur Supabase :
#   supabase secrets set TELEGRAM_GATEWAY_TOKEN=tg_gt_votre_token
#   supabase functions deploy telegram-gateway

# Capacitor — live reload en dev (IP LAN + port Vite, ex. http://192.168.1.10:5173)
# Option rapide : npm run cap:dev puis npm run cap:dev:sync (depuis moxt-react)
# CAPACITOR_SERVER_URL=http://192.168.1.10:5173

# Deep links natifs (exemples)
# com.moxt.app://transfers/ID
# moxt://app/marketplace
