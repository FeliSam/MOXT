{
  "name": "moxt",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ../node_modules/vite/bin/vite.js",
    "build": "node scripts/prepare-netlify-env.mjs && node ../node_modules/vite/bin/vite.js build",
    "build:capacitor": "npm run build",
    "cap:assets": "node scripts/sync-capacitor-assets.mjs",
    "cap:doctor": "cap doctor",
    "cap:copy": "npm run build:capacitor && cap copy",
    "cap:sync": "npm run build:capacitor && npm run cap:assets && cap sync",
    "cap:run:android": "npm run cap:sync && cap run android",
    "cap:run:ios": "npm run cap:sync && cap run ios",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "cap:gradle:ensure": "powershell -ExecutionPolicy Bypass -File scripts/ensure-gradle.ps1",
    "cap:dev": "node scripts/cap-dev.mjs",
    "cap:dev:sync": "node scripts/cap-dev.mjs --sync",
    "cap:prod:sync": "node scripts/cap-prod.mjs",
    "cap:prod:android": "node scripts/cap-prod.mjs && cap open android",
    "lint": "eslint .",
    "test": "node ../node_modules/vitest/vitest.mjs run",
    "test:watch": "node ../node_modules/vitest/vitest.mjs",
    "test:e2e": "node scripts/run-e2e.mjs",
    "quality": "node scripts/check-quality.mjs",
    "validate": "npm run format && npm run lint && npm run test && npm run build && npm run quality && npm run test:e2e",
    "format": "prettier --write .",
    "preview": "node ../node_modules/vite/bin/vite.js preview",
    "serve:dist": "node scripts/serve-dist.mjs",
    "assets": "node scripts/generate-assets.mjs && node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@moxt/shared": "*",
    "@reduxjs/toolkit": "^2.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@zxing/browser": "^0.2.1",
    "formik": "^2.4.9",
    "react": "19.2.3",
    "react-dom": "19.2.7",
    "react-icons": "^5.6.0",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.17.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
