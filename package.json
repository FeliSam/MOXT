{
  "name": "moxt-monorepo",
  "private": true,
  "workspaces": [
    "moxt-react",
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "postinstall": "node scripts/link-expo-router.cjs",
    "web": "npm run dev -w moxt",
    "web:build": "npm run build -w moxt",
    "web:deploy:yandex": "node scripts/deploy-yandex.mjs",
    "deploy:yandex": "npm run web:deploy:yandex",
    "web:deploy:yandex:init": "node scripts/deploy-yandex.mjs --init",
    "setup:github-yandex": "node scripts/setup-github-yandex.mjs",
    "setup:github-secrets": "node scripts/setup-github-secrets.mjs",
    "setup:github": "node scripts/setup-github-yandex.mjs && node scripts/setup-github-secrets.mjs",
    "setup:github:win": "powershell -ExecutionPolicy Bypass -File scripts/setup-github-secrets.ps1",
    "setup:yc": "node scripts/setup-yc-local.mjs",
    "setup:yandex-cdn": "node scripts/setup-yandex-cdn.mjs",
    "setup:yandex-cdn:recreate": "node scripts/setup-yandex-cdn-recreate.mjs",
    "setup:site-online": "node scripts/setup-site-online.mjs",
    "setup:site-dns": "node scripts/sync-site-dns.mjs",
    "verify:deploy": "node scripts/verify-deploy-version.mjs",
    "check:site": "node scripts/check-site.mjs",
    "check:smsc": "node scripts/check-smsc.mjs",
    "test:sms": "node scripts/test-sms-pipeline.mjs",
    "setup:yandex-provision": "node scripts/provision-yandex-auth.mjs",
    "setup:yandex-all": "node scripts/setup-yandex-all.mjs",
    "setup:phase2": "node scripts/setup-phase2-postbox-sms.mjs",
    "setup:sms-ru": "node scripts/setup-sms-ru.mjs",
    "setup:smsc": "node scripts/setup-smsc.mjs",
    "setup:admin-promote": "node scripts/setup-admin-promote.mjs",
    "setup:google-auth": "node scripts/setup-google-auth.mjs",
    "setup:postbox": "node scripts/setup-postbox-domain.mjs",
    "setup:smtp": "node scripts/setup-smtp.mjs",
    "setup:cns": "node scripts/setup-cns-sms.mjs",
    "setup:supabase": "node scripts/setup-supabase.mjs",
    "push:generate-vapid": "node scripts/generate-vapid-keys.mjs",
    "setup:push": "node scripts/setup-push.mjs",
    "setup:push:native": "node scripts/setup-push-native.mjs",
    "push:simulate": "node scripts/simulate-push-pipeline.mjs",
    "db:push": "node scripts/db-push.mjs",
    "deploy:all": "node scripts/deploy-all.mjs --parallel",
    "moxt": "node scripts/moxt.mjs",
    "ship": "node scripts/moxt.mjs ship --purge-cdn",
    "go": "node scripts/moxt.mjs ship --purge-cdn",
    "cpd": "node scripts/moxt.mjs ship --purge-cdn",
    "tout": "node scripts/moxt.mjs ship --purge-cdn",
    "fix": "node scripts/moxt.mjs fix",
    "check:push": "node scripts/check-push.mjs",
    "setup:production": "node scripts/setup-production.mjs",
    "web:cap:doctor": "npm run cap:doctor -w moxt",
    "web:cap:copy": "npm run cap:copy -w moxt",
    "web:cap:sync": "npm run cap:sync -w moxt",
    "web:cap:run:android": "npm run cap:run:android -w moxt",
    "web:cap:run:ios": "npm run cap:run:ios -w moxt",
    "web:cap:add:android": "npm run cap:add:android -w moxt",
    "web:cap:add:ios": "npm run cap:add:ios -w moxt",
    "web:cap:open:android": "npm run cap:open:android -w moxt",
    "web:cap:open:ios": "npm run cap:open:ios -w moxt",
    "web:cap:dev": "npm run cap:dev -w moxt",
    "web:cap:dev:sync": "npm run cap:dev:sync -w moxt",
    "web:cap:prod:sync": "npm run cap:prod:sync -w moxt",
    "web:cap:prod:android": "npm run cap:prod:android -w moxt",
    "web:test": "npm run test -w moxt",
    "mobile": "npm run start --prefix apps/mobile",
    "mobile:lan": "npm run start --prefix apps/mobile",
    "mobile:tunnel": "npm run start:tunnel --prefix apps/mobile",
    "mobile:tunnel:fresh": "npm run start:tunnel:fresh --prefix apps/mobile",
    "mobile:android": "npm run android --prefix apps/mobile",
    "mobile:ios": "npm run ios --prefix apps/mobile",
    "mobile:eas:go": "npm run eas:go --prefix apps/mobile",
    "shared:test": "npm run test -w @moxt/shared",
    "test": "npm run shared:test && npm run web:test",
    "i18n:export": "node scripts/i18n-translations.mjs export",
    "i18n:import": "node scripts/i18n-translations.mjs import",
    "i18n:import:apply": "node scripts/i18n-translations.mjs import --apply"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/client-sesv2": "^3.1083.0",
    "@aws-sdk/client-sns": "^3.1083.0",
    "@aws-sdk/lib-storage": "^3.1085.0",
    "jsdom": "^29.1.1",
    "styleq": "^0.1.3",
    "supabase": "^2.109.1",
    "tweetsodium": "^0.0.4",
    "typescript": "~6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.8",
    "web-push": "^3.6.7"
  },
  "overrides": {
    "vite": "^8.1.2",
    "expo": "~57.0.0",
    "expo-modules-core": "~57.0.0"
  },
  "dependencies": {
    "merge-options": "^3.0.4"
  }
}
