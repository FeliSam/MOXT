# Généré automatiquement par : npm run setup:yandex-provision
# Ne pas commiter (scripts/phase2.env est dans .gitignore)
#
# Pour régénérer les clés : MOXT_PROVISION_FORCE=1 npm run setup:yandex-provision

# Yandex CDN (rempli par npm run setup:yandex-cdn:recreate)
# MOXT_CDN_RESOURCE_ID=

# REG.RU API 2 — https://www.reg.ru/user/account/#/settings/api/
# Ajoutez l'IP de cette machine dans les IP autorisées REG.RU
# MOXT_REGRU_USERNAME=
# MOXT_REGRU_PASSWORD=*

# SUPABASE_ACCESS_TOKEN=   # https://supabase.com/dashboard/account/tokens (CI migrations)
# Mot de passe DB Supabase (Settings → Database) — requis pour npm run db:push
# SUPABASE_DB_PASSWORD=

# SMS.ru — OTP téléphone rapide (npm run setup:sms-ru)
# Clé API : https://sms.ru → личный кабинет → api_id
# SMS_RU_API_ID=
# SMS_PROVIDER=smsru
# SMS_RU_FROM=MOXT
# SMS_MESSAGE_TEMPLATE=Код MOXT: {otp}. Никому не сообщайте.

# SMSC.ru — envoi OTP + réception SMS (npm run setup:smsc)
# Compte : https://smsc.ru → Paramètres → API / SMPP
# SMSC_LOGIN=
# SMSC_PASSWORD=
# SMSC_API_KEY=          # alternative au mot de passe
# SMS_PROVIDER=smsc
# SMSC_SENDER=MOXT
# SMSC_WEBHOOK_SECRET=   # généré par setup:smsc
# SMSC_INBOUND_PHONE=    # numéro virtuel loué (optionnel, pour tests)

# Promotion admin — mot de passe obligatoire pour créer un admin (npm run setup:admin-promote)
# MOXT_ADMIN_PROMOTE_PASSWORD=

# Push natif Capacitor — Firebase FCM (npm run setup:firebase puis setup:push:native)
# 1) npm run firebase:login
# 2) npm run setup:firebase -- --project=VOTRE_PROJECT_ID
# 3) Télécharger la clé compte de service → scripts/firebase-service-account.json
# 4) npm run setup:push:native
# FCM_SERVICE_ACCOUNT_PATH=scripts/firebase-service-account.json
# FCM_GOOGLE_SERVICES_PATH=moxt-react/android/app/google-services.json
# FCM_PROJECT_ID=

# RuStore (publication Android RU) — npm run check:rustore
# Console : https://console.rustore.ru → API → créer une clé
# La console FR peut afficher une modal « Clé API » (Base64 PKCS#8) SANS télécharger de .pem.
# Le fichier scripts/rustore-private-key.pem n’est PAS fourni par RuStore : on le crée localement.
# 1) Noter le keyId COURT (liste des clés) — ne jamais y coller la clé privée
# 2) Copier AUSSI TÔT le Base64 de la modal → scripts/rustore-private-key.pem
#    Accepte : PEM complet (BEGIN/END) OU Base64 seul (whitespace OK)
# 3) Repli : RUSTORE_PRIVATE_KEY=... dans ce fichier si le .pem manque (même contenu)
# Préférer le fichier (RUSTORE_PRIVATE_KEY_PATH) pour garder phase2.env lisible
# RUSTORE_KEY_ID=
# RUSTORE_PRIVATE_KEY_PATH=scripts/rustore-private-key.pem
# RUSTORE_PRIVATE_KEY=   # optionnel — repli si fichier absent (PEM ou Base64)
# RUSTORE_PACKAGE_NAME=com.moxt.app
